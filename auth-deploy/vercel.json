      "destination": "/api/credits-trophies?service=generation&sub=plugin-event"
    },
    {
      "source": "/api/admin/generation-learning-summary",
      "destination": "/api/credits-trophies?service=admin&sub=generation-learning-summary"
    },
    {
      "source": "/api/generate/threads",
      "destination": "/api/credits-trophies?service=generate-chat&sub=threads"
    },
    {
      "source": "/api/generate/thread-messages",
      "destination": "/api/credits-trophies?service=generate-chat&sub=thread-messages"
    },
    {
