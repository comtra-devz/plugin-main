# In produzione (deploy) lascia vuoto: le API sono same-origin (/api/admin, /api/admin-auth).
# In dev locale puoi mettere l'URL della dashboard deployata.
# VITE_ADMIN_API_URL=

# Backward compat: se non usi login con JWT, le API accettano ancora questo secret.
# Con login email+password+2FA il frontend invia il JWT dopo il login.
VITE_ADMIN_SECRET=
